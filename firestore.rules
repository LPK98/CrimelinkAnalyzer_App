rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /messages/{messageId} {
      allow read: if true;

      allow create: if request.resource.data.type in ['text', 'image', 'audio']
                    && request.resource.data.conversationId is string
                    && request.resource.data.senderId is string
                    && request.resource.data.recipientId is string
                    && request.resource.data.senderId != request.resource.data.recipientId
                    && (
                      (request.resource.data.type == 'text' && request.resource.data.text is string) ||
                      (request.resource.data.type in ['image', 'audio'] && request.resource.data.mediaUrl is string)
                    );

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
